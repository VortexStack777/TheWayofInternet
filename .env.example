# Discord Webhook URL for the feedback system
# Create a webhook in your Discord server channel settings:
#   Server Settings > Integrations > Webhooks > New Webhook
# Copy the webhook URL and paste it below (no quotes).
DISCORD_FEEDBACK_WEBHOOK=https://discord.com/api/webhooks/your_feedback_webhook_id/your_webhook_token
DISCORD_SUGGEST_EDIT_WEBHOOK=https://discord.com/api/webhooks/your_suggest_edit_webhook_id/your_webhook_token
